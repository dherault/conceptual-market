{
  "private": true,
  "version": "0.0.0",
  "name": "conceptual-market-backend",
  "description": "Backend for Conceptual Market",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "NODE_ENV=production tsx src/index.ts",
    "start:dev": "NODE_ENV=development PORT=3003 GOOGLE_APPLICATION_CREDENTIALS=google-application-credentials.json tsx src/index.ts",
    "start:watch": "nodemon --watch src --ext ts,json --exec \"npm run start:dev\"",
    "dev": "npm run start:watch",
    "dev:stripe": "stripe listen --forward-to localhost:3003/stripe/webhook",
    "lint": "tsc -b && eslint src --ext ts --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "tsc -b && eslint src --ext ts --report-unused-disable-directives --max-warnings 0 --fix",
    "deploy": "npm run deploy:patch",
    "deploy:patch": "npm run deploy:check-auth && npm version patch && npm run deploy:commit && npm run deploy:gcloud",
    "deploy:minor": "npm run deploy:check-auth && npm version minor && npm run deploy:commit && npm run deploy:gcloud",
    "deploy:major": "npm run deploy:check-auth && npm version major && npm run deploy:commit && npm run deploy:gcloud",
    "deploy:check-auth": "gcloud auth print-access-token > /dev/null 2>&1 || gcloud auth login",
    "deploy:commit": "cd .. && git add backend package-lock.json && git commit -m \"[backend] Deploy\"",
    "deploy:gcloud": "gcloud run deploy conceptual-market-backend --source .. --project conceptual-market --allow-unauthenticated --platform managed --cpu 1 --memory 1Gi --timeout 3600 --concurrency 64",
    "migrate:development:up:1": "IS_LOCAL=true NODE_ENV=development GOOGLE_APPLICATION_CREDENTIALS=google-application-credentials.json tsx src/migrations/logic/index.ts up 1",
    "migrate:development:up:3": "IS_LOCAL=true NODE_ENV=development GOOGLE_APPLICATION_CREDENTIALS=google-application-credentials.json tsx src/migrations/logic/index.ts up 3",
    "migrate:development:down:1": "IS_LOCAL=true NODE_ENV=development GOOGLE_APPLICATION_CREDENTIALS=google-application-credentials.json tsx src/migrations/logic/index.ts down 1",
    "migrate:development:down:3": "IS_LOCAL=true NODE_ENV=development GOOGLE_APPLICATION_CREDENTIALS=google-application-credentials.json tsx src/migrations/logic/index.ts down 3",
    "migrate:production:up:1": "IS_LOCAL=true NODE_ENV=production GOOGLE_APPLICATION_CREDENTIALS=google-application-credentials.json tsx src/migrations/logic/index.ts up 1",
    "migrate:production:down:1": "IS_LOCAL=true NODE_ENV=production GOOGLE_APPLICATION_CREDENTIALS=google-application-credentials.json tsx src/migrations/logic/index.ts down 1",
    "kill": "kill -9 $(lsof -t -i:3003) 2>/dev/null || true",
    "check": "npx knip"
  },
  "dependencies": {
    "@google-cloud/language": "^7.2.1",
    "@google-cloud/logging-winston": "^6.0.1",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google/genai": "^1.43.0",
    "axios": "^1.13.6",
    "conceptual-market-core": "*",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.7.0",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.6",
    "slugify": "^1.6.6",
    "tsx": "^4.21.0",
    "unfluff": "^3.2.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash.isplainobject": "^4.0.9",
    "lodash.isplainobject": "^4.0.6",
    "nodemon": "^3.1.14",
    "typescript": "^5.9.3"
  }
}
